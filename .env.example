# =============================================================
# SUPPORT SERVICE — STARTUP ORDER
# =============================================================
# Services must be started in this order in development:
#
#   1. cd clublaze-auth-service && docker-compose -f docker-compose.dev.yml up
#      (support-service resolves requesters and university admins through it)
#
#   2. cd clublaze-notification-service && docker-compose -f docker-compose.dev.yml up
#      (support-service calls its internal endpoints to email/notify people)
#
#   3. cd support-service && docker-compose -f docker-compose.dev.yml up
#      (needs its own MongoDB database — see below — and starts Redis)
#
#   4. cd clublaze-frontend && npm run dev
#
# This service does not consume or produce Kafka events. It talks to
# auth-service and notification-service directly over HTTP, the same way
# user-profile-service's authServiceClient.js does.
# =============================================================
# ── Server ──────────────────────────────────────────────────────────────────
PORT=8007
NODE_ENV=development
FRONTEND_BASE_URL=http://localhost:5173

# ── MongoDB ─────────────────────────────────────────────────────────────────
# NOTE: matches the MONGODB_URI naming used by club-service, profile-service,
# notification-service etc. (auth-service alone uses MONGO_URI).
# Each service — this one included — connects to its own separate database.
# Create a new database (e.g. unihub_support) in your existing Atlas cluster,
# or point at a local MongoDB instance if you'd rather run one.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.y30ju06.mongodb.net/unihub_support?appName=Cluster0
MONGO_NETWORK_FAMILY=4
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_STARTUP_RETRY_MS=10000

# ── Redis ───────────────────────────────────────────────────────────────────
# Used for the university-admins lookup cache and the chat rate limiter.
REDIS_URL=redis://localhost:6379

# ── JWT ─────────────────────────────────────────────────────────────────────
# Must equal JWT_ACCESS_SECRET from auth-service .env exactly.
JWT_SECRET=your_jwt_secret_here_must_match_auth_service

# ── Internal service communication ─────────────────────────────────────────
# Must be identical to INTERNAL_SERVICE_SECRET in every other service's .env
INTERNAL_SERVICE_SECRET=your_internal_service_secret_here
SENTRY_DSN=

# ── Other service URLs ──────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:8001
AUTH_SERVICE_TIMEOUT_MS=2500
AUTH_USER_CACHE_TTL_MS=60000
AUTH_USER_STALE_TTL_MS=300000
NOTIFICATION_SERVICE_URL=http://localhost:8004
# club-service owns the shared audit log — support actions are recorded via its
# POST /api/v1/internal/audit endpoint. See utils/auditServiceClient.js.
CLUB_SERVICE_URL=http://localhost:8002
AUDIT_SERVICE_TIMEOUT_MS=3000

# ── AWS S3 (ticket & reply attachments) ─────────────────────────────────────
# Leave empty in development — s3.util.js throws a clear 503 instead of
# silently failing if a request actually needs storage.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=unihub-uploads
AWS_S3_BASE_URL=

# ── Upload limits ────────────────────────────────────────────────────────────
MAX_ATTACHMENT_SIZE_MB=10
MAX_ATTACHMENTS_PER_TICKET=5

# ── AI chat (support assistant) ─────────────────────────────────────────────
# Same Anthropic key already powering club-service's academicCalendarExtraction.
# Check docs.claude.com for the current model name before deploying — this
# default will drift out of date the same way academicCalendarExtraction's did.
ANTHROPIC_API_KEY=
SUPPORT_CHAT_MODEL=claude-haiku-4-5
SUPPORT_CHAT_TIMEOUT_MS=15000
SUPPORT_CHAT_MAX_TOKENS=800
SUPPORT_CHAT_RATE_LIMIT_PER_HOUR=30
